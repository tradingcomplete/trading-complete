  }
  
  // === 表記ルール(全タイプ共通・★v13.1 S4: 【フォーマットルール】から改名して統合セクションと区別) ===
  rules += '\n【表記ルール】\n'; 
  rules += '・ハッシュタグは書くな(システムが自動付与)。リスト記号(・●1.-)禁止\n';
