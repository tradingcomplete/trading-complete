  // ★v12.7: NY投稿セクション削除（NYタイプ廃止のため）
  
  // ②-c2 月曜日コンテキスト（市場系全投稿共通）★v5.6追加
  var todayDayOfWeek = now.getDay(); // 0=日, 1=月, ..., 6=土
