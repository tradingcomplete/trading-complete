  // === NG例（★v8.6: 市場系とRULE系で分離） ===
  if (needsMarketRules) {
    rules += '\n【NG例】\n';
    rules += '× レート数字の羅列 × 前置き挨拶 × 呼びかけ × 投稿タイプ名 × 架空トレード結果（「ロングした」「利確した」）\n';
